{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["./src/renderer/src/*"],
      "@shared": ["./packages/shared/src/index.ts"],
      "@shared/*": ["./packages/shared/src/*"]
    },
    "types": ["vite/client"]
  },
  "include": ["src/renderer/**/*", "packages/shared/src"],
  "vueCompilerOptions": {
    "target": 3
  }
}
